mdl 1.5;
import ::anno::in_group;
import ::df::diffuse_reflection_bsdf;
import ::df::diffuse_edf;
import ::state::normal;
export material WhiteShadowCatcher()
 =
    let {
        material_surface surface(
            scattering: ::df::diffuse_reflection_bsdf(color(1.f, 1.f, 1.f), 0.f)
            );
        material_surface backface(
            scattering: ::df::diffuse_reflection_bsdf(color(1.f, 1.f, 1.f), 0.f)
            );
    } in material(
            thin_walled: true,
            surface: surface,
            backface: backface);
