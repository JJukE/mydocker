export using ::tex import wrap_mode;

using ::scene import data_lookup_float, data_lookup_float2, data_lookup_float3, data_lookup_float4, data_lookup_int;

annotation annotation_port_displayName(string s);
annotation annotation_port_displayType(string s);
annotation annotation_not_connectable();
annotation annotation_widget_type(string s);


export float
[[
    annotation_port_displayName("result")
]]
UsdPrimvarReader_float
(
    uniform string varname = "",
    float fallback = 0.0f
)
{
    return data_lookup_float(varname, fallback);
}


