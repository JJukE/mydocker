mdl 1.5;
import ::anno::in_group;
import ::df::diffuse_reflection_bsdf;
import ::df::diffuse_edf;
import ::state::normal;
export material DebugWhiteEmissive()
 = 
    let {
        material_surface surface(
            emission:  material_emission(
                df::diffuse_edf(),
                intensity: color(1000.f)
		    ));
        material_surface backface(
            emission:  material_emission(
                df::diffuse_edf(),
                intensity: color(1000.f)
		    ));
    } in material(
            thin_walled: true,
            surface: surface,
            backface: backface);
