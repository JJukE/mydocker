mdl 1.8;

import ::anno::*;
import ::base::*;
import ::tex::*;

import UsdPreviewSurface::*;
import UsdPreviewSurfaceLib::*;

using ::tex import wrap_mode;
using UsdPreviewSurfaceLib import texture_channel_select;
using UsdPreviewSurfaceLib import connection_type;

export enum uv_source
{
    geometry,
    parameter
};


float4 get_texture_value
(
    uniform texture_2d file,
    uniform wrap_mode wrapS,
    uniform wrap_mode wrapT,
    uniform float4 scale,
    uniform float4 bias,

    uniform string varname,
    uniform float4 fallback,

    uniform float XF_rotation,
    uniform float2 XF_scale,
    uniform float2 XF_translation,

    uniform uv_source UV_source,
    uniform float2 UV_st,
    uniform string UV_varname,
    uniform float2 UV_fallback
)
{
    if (tex::texture_isvalid(file))
    {
        // default to state::texture_coordinate(0)
        // which is "st" or "st0"
        base::texture_coordinate_info uvw;

        if (UV_source == parameter)
        {
            uvw.position = float3(UV_st.x, UV_st.y, 0.0f);
        }
        else if ((UV_varname != "st") && (UV_varname != "st0"))
        {
            float2 st_lookup = UsdPreviewSurface::UsdPrimvarReader_float2(UV_varname, UV_fallback);
            uvw.position = float3(st_lookup.x, st_lookup.y, 0.0f);
        }

        float2 uv = UsdPreviewSurface::UsdTransform2d(
            float2(uvw.position[0], uvw.position[1]),
            XF_rotation,
            XF_scale,
            XF_translation);

        UsdPreviewSurface::TextureReturnOut texRet =
            UsdPreviewSurface::UsdUVTexture(
                file,
                uv,
                wrapS,
                wrapT,
                fallback,
                scale,
                bias
            );

        return float4(texRet.r, texRet.g, texRet.b, texRet.a);
    }

    return UsdPreviewSurface::UsdPrimvarReader_float4(varname, fallback);
}



float get_float_parameter
(
    float inVal,
    uniform connection_type connectionType,
    uniform float PV_fallback,
    uniform string varname,
    uniform float4 fallback,

    uniform float XF_rotation,
    uniform float2 XF_scale,
    uniform float2 XF_translation,

    uniform texture_2d file,
    uniform wrap_mode wrapS,
    uniform wrap_mode wrapT,
    uniform float4 scale,
    uniform float4 bias,
    uniform texture_channel_select channel,

    uniform uv_source UV_source,
    uniform float2 UV_st,
    uniform string UV_varname,
    uniform float2 UV_fallback
)
{
    return connectionType == none
        ? inVal
        : (connectionType == primvar
            ? UsdPreviewSurface::UsdPrimvarReader_float(varname, PV_fallback)
            : UsdPreviewSurfaceLib::float4_to_float(get_texture_value(
                file,
                wrapS,
                wrapT,
                scale,
                bias,
                varname,
                fallback,
                XF_rotation,
                XF_scale,
                XF_translation,
                UV_source,
                UV_st,
                UV_varname,
                UV_fallback
             ), channel));
}


float3 get_float3_parameter
(
    float3 inVal,
    uniform connection_type connectionType,
    uniform float3 PV_fallback,

    uniform string varname,
    uniform float4 fallback,

    uniform float XF_rotation,
    uniform float2 XF_scale,
    uniform float2 XF_translation,

    uniform texture_2d file,
    uniform wrap_mode wrapS,
    uniform wrap_mode wrapT,
    uniform float4 scale,
    uniform float4 bias,
    uniform texture_channel_select channel,

    uniform uv_source UV_source,
    uniform float2 UV_st,
    uniform string UV_varname,
    uniform float2 UV_fallback
)
{
    return connectionType == none
        ? inVal
        : (connectionType == primvar
            ? UsdPreviewSurface::UsdPrimvarReader_float3(varname, PV_fallback)
            : UsdPreviewSurfaceLib::float4_to_float3(get_texture_value(
                file,
                wrapS,
                wrapT,
                scale,
                bias,
                varname,
                fallback,
                XF_rotation,
                XF_scale,
                XF_translation,
                UV_source,
                UV_st,
                UV_varname,
                UV_fallback
             ), channel));
}


export material UsdPreviewSurfaceMonolithic
(
    color diffuseColor = color(0.18f),
        uniform connection_type diffuseColor_connectionType = none,
        uniform string diffuseColor_varname = "",
        uniform float4 diffuseColor_fallback = float4(0.0, 0.0, 0.0, 1.0),
        uniform float3 diffuseColor_PV_fallback = float3(0.0, 0.0, 0.0),

        uniform float diffuseColor_XF_rotation = 0.0f,
        uniform float2 diffuseColor_XF_scale = float2(1.0f),
        uniform float2 diffuseColor_XF_translation = float2(0.0f),

        uniform texture_2d diffuseColor_file = texture_2d(),
        uniform wrap_mode diffuseColor_wrapS = ::tex::wrap_clip,
        uniform wrap_mode diffuseColor_wrapT = ::tex::wrap_clip,
        uniform float4 diffuseColor_scale = float4(1.0f),
        uniform float4 diffuseColor_bias = float4(0.0f),
        uniform string diffuseColor_sourceColorSpace = "auto"
            [[
                anno::unused()
            ]],
        uniform texture_channel_select diffuseColor_channel = rgb,

        uniform uv_source diffuseColor_UV_source = geometry,
        uniform float2 diffuseColor_UV_st = float2(0.0f, 0.0f),
        uniform string diffuseColor_UV_varname = "",
        uniform float2 diffuseColor_UV_fallback = float2(0.0f, 0.0f),

    color emissiveColor = color(0.0),
        uniform connection_type emissiveColor_connectionType = none,
        uniform string emissiveColor_varname = "",
        uniform float4 emissiveColor_fallback = float4(0.0, 0.0, 0.0, 1.0),
        uniform float3 emissiveColor_PV_fallback = float3(0.0, 0.0, 0.0),

        uniform float emissiveColor_XF_rotation = 0.0f,
        uniform float2 emissiveColor_XF_scale = float2(1.0f),
        uniform float2 emissiveColor_XF_translation = float2(0.0f),

        uniform texture_2d emissiveColor_file = texture_2d(),
        uniform wrap_mode emissiveColor_wrapS = ::tex::wrap_clip,
        uniform wrap_mode emissiveColor_wrapT = ::tex::wrap_clip,
        uniform float4 emissiveColor_scale = float4(1.0f),
        uniform float4 emissiveColor_bias = float4(0.0f),
        uniform string emissiveColor_sourceColorSpace = "auto"
            [[
                anno::unused()
            ]],
        uniform texture_channel_select emissiveColor_channel = rgb,

        uniform uv_source emissiveColor_UV_source = geometry,
        uniform float2 emissiveColor_UV_st = float2(0.0f, 0.0f),
        uniform string emissiveColor_UV_varname = "",
        uniform float2 emissiveColor_UV_fallback = float2(0.0f, 0.0f),

    uniform float emissiveScale = 1133.6
        [[
            anno::hidden()
        ]],

    uniform int useSpecularWorkflow = 0,

    color specularColor = color(0.0),
        uniform connection_type specularColor_connectionType = none,
        uniform string specularColor_varname = "",
        uniform float4 specularColor_fallback = float4(0.0, 0.0, 0.0, 1.0),
        uniform float3 specularColor_PV_fallback = float3(0.0, 0.0, 0.0),

        uniform float specularColor_XF_rotation = 0.0f,
        uniform float2 specularColor_XF_scale = float2(1.0f),
        uniform float2 specularColor_XF_translation = float2(0.0f),

        uniform texture_2d specularColor_file = texture_2d(),
        uniform wrap_mode specularColor_wrapS = ::tex::wrap_clip,
        uniform wrap_mode specularColor_wrapT = ::tex::wrap_clip,
        uniform float4 specularColor_scale = float4(1.0f),
        uniform float4 specularColor_bias = float4(0.0f),
        uniform string specularColor_sourceColorSpace = "auto"
            [[
                anno::unused()
            ]],
        uniform texture_channel_select specularColor_channel = rgb,

        uniform uv_source specularColor_UV_source = geometry,
        uniform float2 specularColor_UV_st = float2(0.0f, 0.0f),
        uniform string specularColor_UV_varname = "",
        uniform float2 specularColor_UV_fallback = float2(0.0f, 0.0f),

    float metallic = 0.0f,
        uniform connection_type metallic_connectionType = none,
        uniform string metallic_varname = "",
        uniform float4 metallic_fallback = float4(0.0, 0.0, 0.0, 1.0),
        uniform float metallic_PV_fallback = float(0.0),

        uniform float metallic_XF_rotation = 0.0f,
        uniform float2 metallic_XF_scale = float2(1.0f),
        uniform float2 metallic_XF_translation = float2(0.0f),

        uniform texture_2d metallic_file = texture_2d(),
        uniform wrap_mode metallic_wrapS = ::tex::wrap_clip,
        uniform wrap_mode metallic_wrapT = ::tex::wrap_clip,
        uniform float4 metallic_scale = float4(1.0f),
        uniform float4 metallic_bias = float4(0.0f),
        uniform string metallic_sourceColorSpace = "auto"
            [[
                anno::unused()
            ]],
        uniform texture_channel_select metallic_channel = r,

        uniform uv_source metallic_UV_source = geometry,
        uniform float2 metallic_UV_st = float2(0.0f, 0.0f),
        uniform string metallic_UV_varname = "",
        uniform float2 metallic_UV_fallback = float2(0.0f, 0.0f),

    float roughness = 0.5f,
        uniform connection_type roughness_connectionType = none,
        uniform string roughness_varname = "",
        uniform float4 roughness_fallback = float4(0.0, 0.0, 0.0, 1.0),
        uniform float roughness_PV_fallback = float(0.0),

        uniform float roughness_XF_rotation = 0.0f,
        uniform float2 roughness_XF_scale = float2(1.0f),
        uniform float2 roughness_XF_translation = float2(0.0f),

        uniform texture_2d roughness_file = texture_2d(),
        uniform wrap_mode roughness_wrapS = ::tex::wrap_clip,
        uniform wrap_mode roughness_wrapT = ::tex::wrap_clip,
        uniform float4 roughness_scale = float4(1.0f),
        uniform float4 roughness_bias = float4(0.0f),
        uniform string roughness_sourceColorSpace = "auto"
            [[
                anno::unused()
            ]],
        uniform texture_channel_select roughness_channel = r,

        uniform uv_source roughness_UV_source = geometry,
        uniform float2 roughness_UV_st = float2(0.0f, 0.0f),
        uniform string roughness_UV_varname = "",
        uniform float2 roughness_UV_fallback = float2(0.0f, 0.0f),

    float clearcoat = 0.0f,
        uniform connection_type clearcoat_connectionType = none,
        uniform string clearcoat_varname = "",
        uniform float4 clearcoat_fallback = float4(0.0, 0.0, 0.0, 1.0),
        uniform float clearcoat_PV_fallback = float(0.0),

        uniform float clearcoat_XF_rotation = 0.0f,
        uniform float2 clearcoat_XF_scale = float2(1.0f),
        uniform float2 clearcoat_XF_translation = float2(0.0f),

        uniform texture_2d clearcoat_file = texture_2d(),
        uniform wrap_mode clearcoat_wrapS = ::tex::wrap_clip,
        uniform wrap_mode clearcoat_wrapT = ::tex::wrap_clip,
        uniform float4 clearcoat_scale = float4(1.0f),
        uniform float4 clearcoat_bias = float4(0.0f),
        uniform string clearcoat_sourceColorSpace = "auto"
            [[
                anno::unused()
            ]],
        uniform texture_channel_select clearcoat_channel = r,

        uniform uv_source clearcoat_UV_source = geometry,
        uniform float2 clearcoat_UV_st = float2(0.0f, 0.0f),
        uniform string clearcoat_UV_varname = "",
        uniform float2 clearcoat_UV_fallback = float2(0.0f, 0.0f),

    float clearcoatRoughness = 0.01f,
        uniform connection_type clearcoatRoughness_connectionType = none,
        uniform string clearcoatRoughness_varname = "",
        uniform float4 clearcoatRoughness_fallback = float4(0.0, 0.0, 0.0, 1.0),
        uniform float clearcoatRoughness_PV_fallback = float(0.0),

        uniform float clearcoatRoughness_XF_rotation = 0.0f,
        uniform float2 clearcoatRoughness_XF_scale = float2(1.0f),
        uniform float2 clearcoatRoughness_XF_translation = float2(0.0f),

        uniform texture_2d clearcoatRoughness_file = texture_2d(),
        uniform wrap_mode clearcoatRoughness_wrapS = ::tex::wrap_clip,
        uniform wrap_mode clearcoatRoughness_wrapT = ::tex::wrap_clip,
        uniform float4 clearcoatRoughness_scale = float4(1.0f),
        uniform float4 clearcoatRoughness_bias = float4(0.0f),
        uniform string clearcoatRoughness_sourceColorSpace = "auto"
            [[
                anno::unused()
            ]],
        uniform texture_channel_select clearcoatRoughness_channel = r,

        uniform uv_source clearcoatRoughness_UV_source = geometry,
        uniform float2 clearcoatRoughness_UV_st = float2(0.0f, 0.0f),
        uniform string clearcoatRoughness_UV_varname = "",
        uniform float2 clearcoatRoughness_UV_fallback = float2(0.0f, 0.0f),

    float opacity = 1.0f,
        uniform connection_type opacity_connectionType = none,
        uniform string opacity_varname = "",
        uniform float4 opacity_fallback = float4(0.0, 0.0, 0.0, 1.0),
        uniform float opacity_PV_fallback = float(0.0),

        uniform float opacity_XF_rotation = 0.0f,
        uniform float2 opacity_XF_scale = float2(1.0f),
        uniform float2 opacity_XF_translation = float2(0.0f),

        uniform texture_2d opacity_file = texture_2d(),
        uniform wrap_mode opacity_wrapS = ::tex::wrap_clip,
        uniform wrap_mode opacity_wrapT = ::tex::wrap_clip,
        uniform float4 opacity_scale = float4(1.0f),
        uniform float4 opacity_bias = float4(0.0f),
        uniform string opacity_sourceColorSpace = "auto"
            [[
                anno::unused()
            ]],
        uniform texture_channel_select opacity_channel = r,

        uniform uv_source opacity_UV_source = geometry,
        uniform float2 opacity_UV_st = float2(0.0f, 0.0f),
        uniform string opacity_UV_varname = "",
        uniform float2 opacity_UV_fallback = float2(0.0f, 0.0f),

    uniform float opacityThreshold = 0.0,

    uniform bool enable_opacity = false,

    uniform bool enable_specular_transmission = false,

    uniform float ior = 1.5,


    float3 normal = float3(0.0, 0.0, 1.0),
        uniform connection_type normal_connectionType = none,
        uniform string normal_varname = "",
        uniform float4 normal_fallback = float4(0.0, 0.0, 0.0, 1.0),
        uniform float3 normal_PV_fallback = float3(0.0, 0.0, 0.0),

        uniform float normal_XF_rotation = 0.0f,
        uniform float2 normal_XF_scale = float2(1.0f),
        uniform float2 normal_XF_translation = float2(0.0f),

        uniform texture_2d normal_file = texture_2d(),
        uniform wrap_mode normal_wrapS = ::tex::wrap_clip,
        uniform wrap_mode normal_wrapT = ::tex::wrap_clip,
        uniform float4 normal_scale = float4(1.0f),
        uniform float4 normal_bias = float4(0.0f),
        uniform string normal_sourceColorSpace = "auto"
            [[
                anno::unused()
            ]],
        uniform texture_channel_select normal_channel = rgb,

        uniform uv_source normal_UV_source = geometry,
        uniform float2 normal_UV_st = float2(0.0f, 0.0f),
        uniform string normal_UV_varname = "",
        uniform float2 normal_UV_fallback = float2(0.0f, 0.0f),

    float displacement = 0.0f,
        uniform connection_type displacement_connectionType = none,
        uniform string displacement_varname = "",
        uniform float4 displacement_fallback = float4(0.0, 0.0, 0.0, 1.0),
        uniform float displacement_PV_fallback = float(0.0),

        uniform float displacement_XF_rotation = 0.0f,
        uniform float2 displacement_XF_scale = float2(1.0f),
        uniform float2 displacement_XF_translation = float2(0.0f),

        uniform texture_2d displacement_file = texture_2d(),
        uniform wrap_mode displacement_wrapS = ::tex::wrap_clip,
        uniform wrap_mode displacement_wrapT = ::tex::wrap_clip,
        uniform float4 displacement_scale = float4(1.0f),
        uniform float4 displacement_bias = float4(0.0f),
        uniform string displacement_sourceColorSpace = "auto"
            [[
                anno::unused()
            ]],
        uniform texture_channel_select displacement_channel = r,

        uniform uv_source displacement_UV_source = geometry,
        uniform float2 displacement_UV_st = float2(0.0f, 0.0f),
        uniform string displacement_UV_varname = "",
        uniform float2 displacement_UV_fallback = float2(0.0f, 0.0f),

    float occlusion = 1.0f,
        uniform connection_type occlusion_connectionType = none,
        uniform string occlusion_varname = "",
        uniform float4 occlusion_fallback = float4(0.0, 0.0, 0.0, 1.0),
        uniform float occlusion_PV_fallback = float(0.0),

        uniform float occlusion_XF_rotation = 0.0f,
        uniform float2 occlusion_XF_scale = float2(1.0f),
        uniform float2 occlusion_XF_translation = float2(0.0f),

        uniform texture_2d occlusion_file = texture_2d(),
        uniform wrap_mode occlusion_wrapS = ::tex::wrap_clip,
        uniform wrap_mode occlusion_wrapT = ::tex::wrap_clip,
        uniform float4 occlusion_scale = float4(1.0f),
        uniform float4 occlusion_bias = float4(0.0f),
        uniform string occlusion_sourceColorSpace = "auto"
            [[
                anno::unused()
            ]],
        uniform texture_channel_select occlusion_channel = r,

        uniform uv_source occlusion_UV_source = geometry,
        uniform float2 occlusion_UV_st = float2(0.0f, 0.0f),
        uniform string occlusion_UV_varname = "",
        uniform float2 occlusion_UV_fallback = float2(0.0f, 0.0f)

) = let {

    color PS_diffuseColor =
        color(get_float3_parameter (
            float3(diffuseColor),
            diffuseColor_connectionType,
            diffuseColor_PV_fallback,
            diffuseColor_varname,
            diffuseColor_fallback,
            diffuseColor_XF_rotation,
            diffuseColor_XF_scale,
            diffuseColor_XF_translation,
            diffuseColor_file,
            diffuseColor_wrapS,
            diffuseColor_wrapT,
            diffuseColor_scale,
            diffuseColor_bias,
            diffuseColor_channel,
            diffuseColor_UV_source,
            diffuseColor_UV_st,
            diffuseColor_UV_varname,
            diffuseColor_UV_fallback
        ));

    color PS_emissiveColor =
        color(get_float3_parameter (
            float3(emissiveColor),
            emissiveColor_connectionType,
            emissiveColor_PV_fallback,
            emissiveColor_varname,
            emissiveColor_fallback,
            emissiveColor_XF_rotation,
            emissiveColor_XF_scale,
            emissiveColor_XF_translation,
            emissiveColor_file,
            emissiveColor_wrapS,
            emissiveColor_wrapT,
            emissiveColor_scale,
            emissiveColor_bias,
            emissiveColor_channel,
            emissiveColor_UV_source,
            emissiveColor_UV_st,
            emissiveColor_UV_varname,
            emissiveColor_UV_fallback
        ));

    color PS_specularColor =
        color(get_float3_parameter (
            float3(specularColor),
            specularColor_connectionType,
            specularColor_PV_fallback,
            specularColor_varname,
            specularColor_fallback,
            specularColor_XF_rotation,
            specularColor_XF_scale,
            specularColor_XF_translation,
            specularColor_file,
            specularColor_wrapS,
            specularColor_wrapT,
            specularColor_scale,
            specularColor_bias,
            specularColor_channel,
            specularColor_UV_source,
            specularColor_UV_st,
            specularColor_UV_varname,
            specularColor_UV_fallback
        ));

    float PS_metallic =
        get_float_parameter (
            metallic,
            metallic_connectionType,
            metallic_PV_fallback,
            metallic_varname,
            metallic_fallback,
            metallic_XF_rotation,
            metallic_XF_scale,
            metallic_XF_translation,
            metallic_file,
            metallic_wrapS,
            metallic_wrapT,
            metallic_scale,
            metallic_bias,
            metallic_channel,
            metallic_UV_source,
            metallic_UV_st,
            metallic_UV_varname,
            metallic_UV_fallback
        );

    float PS_roughness =
        get_float_parameter (
            roughness,
            roughness_connectionType,
            roughness_PV_fallback,
            roughness_varname,
            roughness_fallback,
            roughness_XF_rotation,
            roughness_XF_scale,
            roughness_XF_translation,
            roughness_file,
            roughness_wrapS,
            roughness_wrapT,
            roughness_scale,
            roughness_bias,
            roughness_channel,
            roughness_UV_source,
            roughness_UV_st,
            roughness_UV_varname,
            roughness_UV_fallback
        );

    float PS_clearcoat =
        get_float_parameter (
            clearcoat,
            clearcoat_connectionType,
            clearcoat_PV_fallback,
            clearcoat_varname,
            clearcoat_fallback,
            clearcoat_XF_rotation,
            clearcoat_XF_scale,
            clearcoat_XF_translation,
            clearcoat_file,
            clearcoat_wrapS,
            clearcoat_wrapT,
            clearcoat_scale,
            clearcoat_bias,
            clearcoat_channel,
            clearcoat_UV_source,
            clearcoat_UV_st,
            clearcoat_UV_varname,
            clearcoat_UV_fallback
        );

    float PS_clearcoatRoughness =
        get_float_parameter (
            clearcoatRoughness,
            clearcoatRoughness_connectionType,
            clearcoatRoughness_PV_fallback,
            clearcoatRoughness_varname,
            clearcoatRoughness_fallback,
            clearcoatRoughness_XF_rotation,
            clearcoatRoughness_XF_scale,
            clearcoatRoughness_XF_translation,
            clearcoatRoughness_file,
            clearcoatRoughness_wrapS,
            clearcoatRoughness_wrapT,
            clearcoatRoughness_scale,
            clearcoatRoughness_bias,
            clearcoatRoughness_channel,
            clearcoatRoughness_UV_source,
            clearcoatRoughness_UV_st,
            clearcoatRoughness_UV_varname,
            clearcoatRoughness_UV_fallback
        );

    float PS_opacity =
        get_float_parameter (
            opacity,
            opacity_connectionType,
            opacity_PV_fallback,
            opacity_varname,
            opacity_fallback,
            opacity_XF_rotation,
            opacity_XF_scale,
            opacity_XF_translation,
            opacity_file,
            opacity_wrapS,
            opacity_wrapT,
            opacity_scale,
            opacity_bias,
            opacity_channel,
            opacity_UV_source,
            opacity_UV_st,
            opacity_UV_varname,
            opacity_UV_fallback
        );

    float3 PS_normal =
        get_float3_parameter (
            normal,
            normal_connectionType,
            normal_PV_fallback,
            normal_varname,
            normal_fallback,
            normal_XF_rotation,
            normal_XF_scale,
            normal_XF_translation,
            normal_file,
            normal_wrapS,
            normal_wrapT,
            normal_scale,
            normal_bias,
            normal_channel,
            normal_UV_source,
            normal_UV_st,
            normal_UV_varname,
            normal_UV_fallback
        );

    float PS_displacement =
        get_float_parameter (
            displacement,
            displacement_connectionType,
            displacement_PV_fallback,
            displacement_varname,
            displacement_fallback,
            displacement_XF_rotation,
            displacement_XF_scale,
            displacement_XF_translation,
            displacement_file,
            displacement_wrapS,
            displacement_wrapT,
            displacement_scale,
            displacement_bias,
            displacement_channel,
            displacement_UV_source,
            displacement_UV_st,
            displacement_UV_varname,
            displacement_UV_fallback
        );

    float PS_occlusion =
        get_float_parameter (
            occlusion,
            occlusion_connectionType,
            occlusion_PV_fallback,
            occlusion_varname,
            occlusion_fallback,
            occlusion_XF_rotation,
            occlusion_XF_scale,
            occlusion_XF_translation,
            occlusion_file,
            occlusion_wrapS,
            occlusion_wrapT,
            occlusion_scale,
            occlusion_bias,
            occlusion_channel,
            occlusion_UV_source,
            occlusion_UV_st,
            occlusion_UV_varname,
            occlusion_UV_fallback
        );

    material base = UsdPreviewSurface::UsdPreviewSurface (
        diffuseColor: PS_diffuseColor,
        emissiveColor: PS_emissiveColor,
        emissiveScale: emissiveScale,
        useSpecularWorkflow: useSpecularWorkflow,
        specularColor: PS_specularColor,
        metallic: PS_metallic,
        roughness: PS_roughness,
        clearcoat: PS_clearcoat,
        clearcoatRoughness: PS_clearcoatRoughness,
        opacity: PS_opacity,
        opacityThreshold: opacityThreshold,
        enable_opacity: enable_opacity,
        enable_specular_transmission: enable_specular_transmission,
        ior: ior,
        normal: PS_normal,
        displacement: PS_displacement,
        occlusion: PS_occlusion
    );

} in material (
    surface:  base.surface,
    ior: base.ior,
    geometry: base.geometry
);
