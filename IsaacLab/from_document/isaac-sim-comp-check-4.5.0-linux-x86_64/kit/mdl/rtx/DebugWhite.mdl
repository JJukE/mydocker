mdl 1.5;
import ::anno::in_group;
import ::df::diffuse_reflection_bsdf;
import ::state::normal;
export material DebugWhite()
 = 
    let {
        material_surface surface(
            ::df::diffuse_reflection_bsdf(color(1.f, 1.f, 1.f), 0.f, ""));
    } in material(
            thin_walled: false,
            surface: surface);
