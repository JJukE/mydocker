mdl 1.4;

import ::anno::*;
export using ::base import texture_return;
//using .::core_definitions import texture_return;
module [[
    anno::version( 1, 1, 0),
    anno::hidden(),
    anno::display_name("NVIDIA auxillary definitions")
]];


// Support functions to simplify conversions between vector types with swizzles
// Supported argument types: float2, float3, float4, color, texture_return (as RGB and RGBA)
// Supported return types: float, float2, float3 color

//constructor wrappers

export float construct_float(texture_return a)
[[
    anno::display_name("Float from texture_return"),
    anno::description("Construct a float."),
    anno::author("NVIDIA Corporation"),
    anno::in_group("Constructor"),
    anno::ui_order(10000)
]]{return a.mono;}
export color construct_color(float a)
[[
    anno::display_name("Color from float"),
    anno::description("Construct a color."),
    anno::author("NVIDIA Corporation"),
    anno::in_group("Constructor"),
    anno::ui_order(10001)
]]{return color(a);}
export color construct_color(float3 a)
[[
    anno::display_name("Color from float3"),
    anno::description("Construct a color."),
    anno::author("NVIDIA Corporation"),
    anno::in_group("Constructor"),
    anno::ui_order(10002)
]]{return color(a);}
export color construct_color(float r, float g, float b)
[[
    anno::display_name("Color from floats"),
    anno::description("Construct a color."),
    anno::author("NVIDIA Corporation"),
    anno::in_group("Constructor"),
    anno::ui_order(10003)
]]{return color(r,g,b);}
