        roughness_u: roughness*roughness
    );
    bsdf transmission_bsdf = df::diffuse_transmission_bsdf(
        tint: translucent_color
    );
    bsdf base_bsdf = df::diffuse_reflection_bsdf(
        tint: surface_color
    );
} in material(
    thin_walled: true,
