        tangent_u: anisotropy_values.tangent_u
    );
} in material(
    thin_walled: true,
    surface: material_surface(
        scattering: df::weighted_layer(
            weight: 1.,
            normal: normal,
            layer: df::weighted_layer(
                weight: glossy_weight,
