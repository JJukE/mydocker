export float3 triplanar_normalmap_texture(
    uniform texture_2d texture_1
    [[
        anno::usage("normal"),
        anno::display_name("Bitmap file"),
        anno::in_group("1st Bitmap parameters"),
        anno::ui_order(0)
    ]],
    float2 scaling_1 = float2(1.)
    [[
        anno::description("Controls the scale of the texture on the object"),
        anno::display_name("Tiling"),
        anno::in_group("1st Bitmap parameters"),
        anno::ui_order(1)
    ]],
    float2 translation_1 = float2(0.)
    [[
        anno::description("Controls position of the texture on the object"),
        anno::display_name("Offset"),
        anno::in_group("1st Bitmap parameters"),
        anno::ui_order(2)
    ]],
    float rotation_1 = 0.
    [[
        anno::description("Rotation angle of the texture in degrees"),
        anno::display_name("Rotation"),
        anno::in_group("1st Bitmap parameters"),
        anno::ui_order(3),
        anno::soft_range(0.0,360.0)
    ]],
    uniform bool flip_1 = false
    [[
        anno::description("Flip handedness of the tangent space"),
        anno::display_name("Flip V"),
        anno::in_group("1st Bitmap parameters"),
        anno::ui_order(4)
    ]],
    uniform texture_2d texture_2 = texture_2d()
    [[
        anno::display_name("Bitmap file"),
        anno::in_group("2nd Bitmap parameters"),
        anno::usage("normal"),
        anno::ui_order(4)
    ]],
    float2 scaling_2 = float2(1.)
    [[
        anno::description("Controls the scale of the texture on the object"),
        anno::display_name("Tiling"),
        anno::in_group("2nd Bitmap parameters"),
        anno::enable_if( "tex::texture_isvalid(texture_2)" ),
        anno::ui_order(5)
    ]],
    float2 translation_2 = float2(0.)
    [[
        anno::description("Controls position of the texture on the object"),
        anno::display_name("Offset"),
        anno::in_group("2nd Bitmap parameters"),
        anno::enable_if( "tex::texture_isvalid(texture_2)" ),
        anno::ui_order(6)
    ]],
    float rotation_2 = 0.
    [[
        anno::description("Rotation angle of the texture in degrees"),
        anno::display_name("Rotation"),
        anno::in_group("2nd Bitmap parameters"),
        anno::ui_order(7),
        anno::enable_if( "tex::texture_isvalid(texture_2)" ),
        anno::soft_range(0.0,360.0)
    ]],
    uniform bool flip_2 = false
    [[
        anno::description("Flip handedness of the tangent space"),
        anno::display_name("Flip V"),
        anno::in_group("2nd Bitmap parameters"),
        anno::ui_order(8)
    ]],
    uniform texture_2d texture_3 = texture_2d()
    [[
        anno::display_name("Bitmap file"),
        anno::in_group("3rd Bitmap parameters"),
        anno::ui_order(8),
        anno::usage("normal")
    ]],
    float2 scaling_3 = float2(1.)
    [[
        anno::description("Controls the scale of the texture on the object"),
        anno::display_name("Tiling"),
        anno::in_group("3rd Bitmap parameters"),
        anno::enable_if( "tex::texture_isvalid(texture_3)" ),
        anno::ui_order(9)
    ]],
    float2 translation_3 = float2(0.)
    [[
        anno::description("Controls position of the texture on the object"),
        anno::display_name("Offset"),
        anno::in_group("3rd Bitmap parameters"),
        anno::enable_if( "tex::texture_isvalid(texture_3)" ),
        anno::ui_order(10)
    ]],
    float rotation_3 = 0.
    [[
        anno::description("Rotation angle of the texture in degrees"),
        anno::display_name("Rotation"),
        anno::in_group("3rd Bitmap parameters"),
        anno::ui_order(11),
        anno::enable_if( "tex::texture_isvalid(texture_3)" ),
        anno::soft_range(0.0,360.0)
    ]],
    uniform bool flip_3 = false
    [[
        anno::description("Flip handedness of the tangent space"),
        anno::display_name("Flip V"),
        anno::in_group("3rd Bitmap parameters"),
        anno::ui_order(12)
    ]],
    float blend_range = 0.5
    [[
        anno::description("Defines the size of the transition area. 0 means hard transition, 1 means blending happens very softly."),
        anno::display_name("Blend range"),
        anno::in_group("Common parameters"),
        anno::ui_order(13),
        anno::hard_range(0.0,1.0)
    ]],
    float strength = 1.0
    [[
        anno::description("Overall strength of the normalmap"),
        anno::display_name("Strength"),
        anno::in_group("Common parameters"),
        anno::ui_order(14),
        anno::soft_range(0.0,10.0)
    ]],
    uniform float3 rotate_origin = float3(0.0)
    [[
        anno::description("Allows manual alignment of the projection with an object"),
        anno::display_name("Rotation of origin"),
        anno::in_group("Placement"),
        anno::ui_order(16),
        anno::soft_range(float3(0.0),float3(360.0))
    ]],
    uniform bool object_space = true
    [[
        anno::description("If off, world space will be used for generating texture coordinates. If on, object space will apply."),
        anno::display_name("Use object space"),
        anno::in_group("Placement"),
        anno::ui_order(15)
    ]]
)
[[
    anno::display_name("Triplanar Normalmap texture"),
    anno::description("Allows texturing using image files of various file formats"),
    anno::thumbnail(".thumbs/file_texture.png"),
    anno::in_group("Texturing, high level"),
    anno::ui_order(32),
    anno::author("NVIDIA Corporation"),
    anno::copyright_notice(COPYRIGHT)
]]
{
    state::coordinate_space space = object_space?state::coordinate_object:state::coordinate_world;

    float3 normal = state::transform_normal(state::coordinate_internal, space, state::normal());
    float3 position_original = state::transform_point(state::coordinate_internal, space, state::position());
    float3 rotation_origin_rad = math::radians(rotate_origin);
    normal = transform_rotate(normal, rotation_origin_rad);
    float3 position = transform_rotate(position_original, rotation_origin_rad);
    float3 ty =
        math::normalize(
            transform_rotate_inv(state::transform_vector(space,state::coordinate_internal,float3(0.,-1.,0.)),rotation_origin_rad));
    float3 tz =
        math::normalize(
            transform_rotate_inv(state::transform_vector(space,state::coordinate_internal,float3(0.,0.,-1.)),rotation_origin_rad));

    float3 weights = math::abs(normal);

    //TODO: blendrange through pow or is there something better? Pow means relatively little area where only 1 texture is looked up
    weights /=math::max_value(weights);
    weights = math::pow(weights,1./math::max(blend_range, 0.001));



    float2 st1 = normal.x>0.0?float2(-position.z,position.y):float2(-position.z,-position.y);
    float3 ts = math::normalize(math::cross(state::normal(),tz));
    float3 tt1 = math::normalize(math::cross(state::normal(),ts));

    float2 st2 = normal.y>0?float2(-position.z,-position.x):float2(-position.z,position.x);

    float2 st3 = normal.z>0?float2(-position.y,position.x):float2(-position.y,-position.x);
    float3 ts3 = math::normalize(math::cross(state::normal(),ty));
    float3 tt3 = math::normalize(math::cross(state::normal(),ts3));

    tt3 = ( (tex::texture_isvalid(texture_3) && flip_3) || flip_1)? -tt3: tt3;
    float3 tt2 = ( (tex::texture_isvalid(texture_2) && flip_2) || flip_1)? -tt1: tt1;
    tt1 = flip_1? -tt1: tt1;

    float rotation_1_rad = math::radians(rotation_1);
    float3 tan_rotation_1_rad = float3(0.0, rotation_1_rad, 0.0);
    float3 n1 = weights.x>0 && tex::texture_isvalid(texture_1)?
        (support_definitions::lookup_float3(
            texture_1,
            support_definitions::transform_st(rotation_1_rad,translation_1,scaling_1,st1))- float3(0.5)) * (2.0 * strength)
        :float3(0.,0.,1.);
    n1 = math::normalize(
        transform_rotate(ts, tan_rotation_1_rad) * n1.x +
        transform_rotate(tt1, tan_rotation_1_rad) * n1.y +
        state::normal() * (n1.z + (1.0 - strength)));

    float rotation_2_rad = math::radians(rotation_2);
    float3 tan_rotation_2_rad = float3(0.0, rotation_2_rad, 0.0);
    float3 n2 = weights.y>0? tex::texture_isvalid(texture_2)?
        (support_definitions::lookup_float3(
            texture_2,
            support_definitions::transform_st(rotation_2_rad,translation_2,scaling_2,st2))- float3(0.5)) * (2.0 * strength)
        :tex::texture_isvalid(texture_1)?(support_definitions::lookup_float3(
            texture_1,
            support_definitions::transform_st(rotation_1_rad,translation_1,scaling_1,st2))- float3(0.5)) * (2.0 * strength)
        :float3(0.,0.,1.):float3(0.,0.,1.);
    n2 = math::normalize(
        transform_rotate(ts, tan_rotation_2_rad) * n2.x +
        transform_rotate(tt2, tan_rotation_2_rad) * n2.y +
        state::normal() * (n2.z + (1.0 - strength)));

    float rotation_3_rad = math::radians(rotation_3);
    float3 tan_rotation_3_rad = float3(0.0, rotation_3_rad, 0.0);
    float3 n3 = weights.z>0? tex::texture_isvalid(texture_3)?
        (support_definitions::lookup_float3(
            texture_3,
            support_definitions::transform_st(rotation_3_rad,translation_3,scaling_3,st3))- float3(0.5)) * (2.0 * strength)
        :tex::texture_isvalid(texture_1)?(support_definitions::lookup_float3(
            texture_1,
            support_definitions::transform_st(rotation_1_rad,translation_1,scaling_1,st3))- float3(0.5)) * (2.0 * strength)
        :float3(0.,0.,1.):float3(0.,0.,1.);
    n3 = math::normalize(
        transform_rotate(ts3, tan_rotation_3_rad) * n3.x +
        transform_rotate(tt3, tan_rotation_3_rad) * n3.y +
        state::normal() * (n3.z + (1.0 - strength)));

    return  blend_3_normals(n1,weights.x,n2,weights.y,n3,weights.z);
}

// Morten S. Mikkelsen, Practical Real-Time Hex-Tiling, Journal of Computer Graphics
// Techniques (JCGT), vol. 11, no. 2, 77-94, 2022
// http://jcgt.org/published/0011/03/05/
struct hextile_data {
    float2 coord1;
    float2 coord2;
    float2 coord3;
    float3 weights;
    float3x3 tangent_rot_mat1;
    float3x3 tangent_rot_mat2;
    float3x3 tangent_rot_mat3;
};

hextile_data hextile_coord(
    float2 coord,
    float rotation,
    float2 rotation_range,
    float scale,
    float2 scale_range,
    float offset,
    float2 offset_range)
{
    float sqrt3_2 = math::sqrt(3.0) * 2.0;

    // scale coord to maintain the original fit
    float2 st = coord * sqrt3_2;

    // skew input space into simplex triangle grid
    // (1, 0, -tan(30), 2*tan(30))
    float2x2 to_skewed = float2x2(1.0, 0.0, -0.57735027, 1.15470054);
    float2 st_skewed = to_skewed * st;

    // barycentric weights
    float2 st_frac = math::frac(st_skewed);
    float3 temp = float3(st_frac.x, st_frac.y, 0.0);
    temp.z = 1.0 - temp.x - temp.y;

    float s = math::step(0.0, -temp.z);
    float s2 = 2.0 * s - 1.0;

    float w1 = -temp.z * s2;
    float w2 = s - temp.y * s2;
    float w3 = s - temp.x * s2;

    // vertex IDs
    int2 base_id = int2(math::floor(st_skewed));
    int si = int(s);
    int2 id1 = base_id + int2(si, si);
    int2 id2 = base_id + int2(si, 1 - si);
    int2 id3 = base_id + int2(1 - si, si);

    // tile center
    float2x2 inv_skewed = float2x2(1.0, 0.0, 0.5, 1.0 / 1.15470054);
    float2 ctr1 = inv_skewed * float2(id1) / float2(sqrt3_2);
    float2 ctr2 = inv_skewed * float2(id2) / float2(sqrt3_2);
    float2 ctr3 = inv_skewed * float2(id3) / float2(sqrt3_2);

    // reuse hash for performance
    float2 seed_offset = float2(0.12345);  // to avoid some zeros
    float2 rand1 = hash22(float2(id1) + seed_offset);
    float2 rand2 = hash22(float2(id2) + seed_offset);
    float2 rand3 = hash22(float2(id3) + seed_offset);

    // randomized rotation matrix
    float2 rr = math::radians(rotation_range);
    float[2] sc1 = math::sincos(math::lerp(rr.x, rr.y, rand1.x * rotation));
    float[2] sc2 = math::sincos(math::lerp(rr.x, rr.y, rand2.x * rotation));
    float[2] sc3 = math::sincos(math::lerp(rr.x, rr.y, rand3.x * rotation));
    float2x2 rm1 = float2x2(sc1[1], -sc1[0], sc1[0], sc1[1]);
    float2x2 rm2 = float2x2(sc2[1], -sc2[0], sc2[0], sc2[1]);
    float2x2 rm3 = float2x2(sc3[1], -sc3[0], sc3[0], sc3[1]);

    // rotation matrix for tangent vectors
    float3x3 trm1 = float3x3(sc1[1], 0.0, sc1[0], 0.0, 1.0, 0.0, -sc1[0], 0.0, sc1[1]);
    float3x3 trm2 = float3x3(sc2[1], 0.0, sc2[0], 0.0, 1.0, 0.0, -sc2[0], 0.0, sc2[1]);
    float3x3 trm3 = float3x3(sc3[1], 0.0, sc3[0], 0.0, 1.0, 0.0, -sc3[0], 0.0, sc3[1]);

    // randomized scale
    float2 sr = scale_range;
    float2 scale1 = math::lerp(1.0, math::lerp(sr.x, sr.y, rand1.y), scale);
    float2 scale2 = math::lerp(1.0, math::lerp(sr.x, sr.y, rand2.y), scale);
    float2 scale3 = math::lerp(1.0, math::lerp(sr.x, sr.y, rand3.y), scale);

    // randomized offset
    float2 offset1 = math::lerp(float2(offset_range.x), float2(offset_range.y), rand1 * offset);
    float2 offset2 = math::lerp(float2(offset_range.x), float2(offset_range.y), rand2 * offset);
    float2 offset3 = math::lerp(float2(offset_range.x), float2(offset_range.y), rand3 * offset);

    // get coord
    float2 st1 = ((coord - ctr1) * rm1 / scale1) + ctr1 + offset1;
    float2 st2 = ((coord - ctr2) * rm2 / scale2) + ctr2 + offset2;
    float2 st3 = ((coord - ctr3) * rm3 / scale3) + ctr3 + offset3;

    hextile_data tile_data = hextile_data(st1, st2, st3, float3(w1, w2, w3), trm1, trm2, trm3);

    return tile_data;
}

export color hextiling_file_texture(
    uniform texture_2d texture
    [[
        anno::display_name("Bitmap file"),
        anno::in_group("Bitmap parameters"),
        anno::ui_order(0)
    ]],
    uniform int texture_space = 0
    [[
        anno::display_name("UV space index"),
        anno::in_group("Bitmap parameters"),
        anno::ui_order(1)
    ]],
    color default_color = color(0.0)
    [[
        anno::display_name("Default color"),
        anno::in_group("Bitmap parameters"),
        anno::ui_order(2)
    ]],
    float2 repeat = float2(1.0, 1.0)
    [[
        anno::display_name("Tiling"),
        anno::in_group("Placement"),
        anno::ui_order(3)
    ]],
    float rotation = 1.0
    [[
        anno::display_name("Rotation"),
        anno::in_group("Randomization"),
        anno::soft_range(0.0, 1.0),
        anno::ui_order(4)
    ]],
    float2 rotation_range = float2(0.0, 360.0)
    [[
        anno::display_name("Rotation Range"),
        anno::in_group("Randomization"),
        anno::ui_order(5)
    ]],
    float scale = 1.0
    [[
        anno::display_name("Scale"),
        anno::in_group("Randomization"),
        anno::soft_range(0.0, 1.0),
        anno::ui_order(6)
    ]],
    float2 scale_range = float2(0.5, 2.0)
    [[
        anno::display_name("Scale Range"),
        anno::in_group("Randomization"),
        anno::ui_order(7)
    ]],
    float offset = 1.0
    [[
        anno::display_name("Offset"),
        anno::in_group("Randomization"),
        anno::soft_range(0.0, 1.0),
        anno::ui_order(8)
    ]],
    float2 offset_range = float2(0.0, 1.0)
    [[
        anno::display_name("Offset Range"),
        anno::in_group("Randomization"),
        anno::ui_order(9)
    ]],
    float falloff = 0.5
    [[
        anno::display_name("Falloff"),
        anno::in_group("Blending"),
        anno::soft_range(0.0, 1.0),
        anno::ui_order(10)
    ]],
    float falloff_contrast = 0.5
    [[
        anno::display_name("Falloff Contrast"),
        anno::in_group("Blending"),
        anno::soft_range(0.0, 1.0),
        anno::ui_order(11)
    ]]
)
[[
    anno::display_name("Hextilng Bitmap texture"),
    anno::description("Allows infinite texturing without obvious repeat patterns."),
    anno::thumbnail(".thumbs/file_texture.png"),
    anno::in_group("Texturing, high level"),
    anno::ui_order(32),
    anno::author("NVIDIA Corporation"),
    anno::copyright_notice(COPYRIGHT)
]]
{
    if (!tex::texture_isvalid(texture))
        return default_color;


    float3 uvw = state::texture_coordinate(texture_space);
    float2 coord = float2(uvw.x, uvw.y) * repeat;

    // get triangle coord
    hextile_data tile_data = hextile_coord(
        coord: coord,
        rotation: rotation,
        rotation_range: rotation_range,
        scale: scale,
        scale_range: scale_range,
        offset: offset,
        offset_range: offset_range
    );

    // lookup texture
    color c1 = tex::lookup_color(texture, tile_data.coord1);
    color c2 = tex::lookup_color(texture, tile_data.coord2);
    color c3 = tex::lookup_color(texture, tile_data.coord3);

    // luminance as weight
    float3 cw = float3(math::luminance(c1), math::luminance(c2), math::luminance(c3));
    cw = math::lerp(float3(1.0), cw, float3(falloff_contrast));

    // blend weights
    float3 w = cw * math::pow(tile_data.weights, 7.0);
    w /= (w.x + w.y + w.z);

    // apply s-curve gain
    if (falloff != 0.5)
    {
        w.x = schlick_gain(w.x, falloff);
        w.y = schlick_gain(w.y, falloff);
        w.z = schlick_gain(w.z, falloff);
        w /= (w.x + w.y + w.z);
    }

    // blend
    color out_color = w.x * c1 + w.y * c2 + w.z * c3;

    return out_color;
}

export float3 hextiling_normalmap_texture(
    uniform texture_2d texture
    [[
        anno::usage("normal"),
        anno::display_name("Bitmap file"),
        anno::in_group("Bitmap parameters"),
        anno::ui_order(0)
    ]],
    uniform int texture_space = 0
    [[
        anno::display_name("UV space index"),
        anno::in_group("Bitmap parameters"),
        anno::ui_order(1)
    ]],
    float3 default_normal = state::normal()
    [[
        anno::display_name("Default normal"),
        anno::in_group("Bitmap parameters"),
        anno::ui_order(2)
    ]],
    float2 repeat = float2(1.0, 1.0)
    [[
        anno::display_name("Tiling"),
        anno::in_group("Placement"),
        anno::ui_order(3)
    ]],
    float rotation = 1.0
    [[
        anno::display_name("Rotation"),
        anno::in_group("Randomization"),
        anno::soft_range(0.0, 1.0),
        anno::ui_order(4)
    ]],
    float2 rotation_range = float2(0.0, 360.0)
    [[
        anno::display_name("Rotation Range"),
        anno::in_group("Randomization"),
        anno::ui_order(5)
    ]],
    float scale = 1.0
    [[
        anno::display_name("Scale"),
        anno::in_group("Randomization"),
        anno::soft_range(0.0, 1.0),
        anno::ui_order(6)
    ]],
    float2 scale_range = float2(0.5, 2.0)
    [[
        anno::display_name("Scale Range"),
        anno::in_group("Randomization"),
        anno::ui_order(7)
    ]],
    float offset = 1.0
    [[
        anno::display_name("Offset"),
        anno::in_group("Randomization"),
        anno::soft_range(0.0, 1.0),
        anno::ui_order(8)
    ]],
    float2 offset_range = float2(0.0, 1.0)
    [[
        anno::display_name("Offset Range"),
        anno::in_group("Randomization"),
        anno::ui_order(9)
    ]],
    float falloff = 0.5
    [[
        anno::display_name("Falloff"),
        anno::in_group("Blending"),
        anno::soft_range(0.0, 1.0),
        anno::ui_order(10)
    ]],
    float strength = 1.0
    [[
        anno::display_name("Strength"),
        anno::in_group("Normal map parameters"),
        anno::ui_order(11),
        anno::soft_range(0.0, 1.0)
    ]],
    uniform bool flip_g = false
    [[
        anno::display_name("Flip V"),
        anno::in_group("Normal map parameters"),
        anno::ui_order(12)
    ]]
)
[[
    anno::display_name("Hextilng Normalmap texture"),
    anno::description("Allows infinite texturing without obvious repeat patterns."),
    anno::thumbnail(".thumbs/file_texture.png"),
    anno::in_group("Texturing, high level"),
    anno::ui_order(32),
    anno::author("NVIDIA Corporation"),
    anno::copyright_notice(COPYRIGHT)
]]
{
    if (!tex::texture_isvalid(texture))
        return default_normal;


    float3 uvw = state::texture_coordinate(texture_space);
    float2 coord = float2(uvw.x, uvw.y) * repeat;

    // get triangle coord
    hextile_data tile_data = hextile_coord(
        coord: coord,
        rotation: rotation,
        rotation_range: rotation_range,
        scale: scale,
        scale_range: scale_range,
        offset: offset,
        offset_range: offset_range
    );

    // lookup normalmap
    float3 nm1 = tex::lookup_float3(texture, tile_data.coord1);
    float3 nm2 = tex::lookup_float3(texture, tile_data.coord2);
    float3 nm3 = tex::lookup_float3(texture, tile_data.coord3);
    nm1.y = flip_g ? 1.0 - nm1.y : nm1.y;
    nm2.y = flip_g ? 1.0 - nm2.y : nm2.y;
    nm3.y = flip_g ? 1.0 - nm3.y : nm3.y;

    // transform to geometry normals
    nm1 = 2.0 * nm1 - 1.0;
    nm2 = 2.0 * nm2 - 1.0;
    nm3 = 2.0 * nm3 - 1.0;
    float3 sn = state::normal();
    float3 tu1 = state::texture_tangent_u(0) * tile_data.tangent_rot_mat1 * strength;
    float3 tu2 = state::texture_tangent_u(0) * tile_data.tangent_rot_mat2 * strength;
    float3 tu3 = state::texture_tangent_u(0) * tile_data.tangent_rot_mat3 * strength;
    float3 tv1 = state::texture_tangent_v(0) * tile_data.tangent_rot_mat1 * strength;
    float3 tv2 = state::texture_tangent_v(0) * tile_data.tangent_rot_mat2 * strength;
    float3 tv3 = state::texture_tangent_v(0) * tile_data.tangent_rot_mat3 * strength;
    float3 n1 = math::normalize(tu1 * nm1.x + tv1 * nm1.y + sn * nm1.z);
    float3 n2 = math::normalize(tu2 * nm2.x + tv2 * nm2.y + sn * nm2.z);
    float3 n3 = math::normalize(tu3 * nm3.x + tv3 * nm3.y + sn * nm3.z);

    // belnd weights
    float3 w = math::pow(tile_data.weights, 7.0);
    w /= (w.x + w.y + w.z);

    // apply s-curve gain
    if (falloff != 0.5)
    {
        w.x = schlick_gain(w.x, falloff);
        w.y = schlick_gain(w.y, falloff);
        w.z = schlick_gain(w.z, falloff);
        w /= (w.x + w.y + w.z);
    }

    // blend
    float3 out_normal = gradient_blend_3_normals(n1, w.x, n2, w.y, n3, w.z);

    return out_normal;
}

