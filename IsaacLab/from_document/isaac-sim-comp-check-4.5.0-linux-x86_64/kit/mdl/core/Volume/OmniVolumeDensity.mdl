// OmniVolumeDensity based on VDB volumes
mdl 1.7;

import ::tex::*;
import ::anno::*;
import ::base::*;
import ::df::*;
import ::state::*;
import ::tex::*;
import ::math::*;


export material OmniVolumeDensity(
    uniform texture_3d volume_density_texture = texture_3d() 
    [[
        anno::display_name("Volume Density Texture"),
        anno::description("Density VDB Texture File."),
        anno::in_group("Base")
    ]],
	uniform color volume_albedo = color(1.f, 1.f, 1.f) 
    [[
        anno::display_name("Volume Color"),
		anno::description("Volume Albedo Color"),
        anno::in_group("Base")
    ]],
    uniform float volume_density_scale = 1.f 
    [[
        anno::display_name("Density Scale"),
		anno::description("Scales the volume density."),
        anno::in_group("Base"),
        anno::usage("")
    ]],
   	uniform float directional_bias = 0.f 
       [[
        anno::display_name("Scattering Phase"),
        anno::description("Forward, backward or isotropic scattering phase. Positive values are forward scattering; Negative are backward scattering; 0 is isotropic scattering."),
        anno::in_group("Base"),
        anno::hard_range(-1, 1)
    ]]
)
[[
    anno::display_name("OmniVolumeDensity"),
    anno::description("3D Density."),
    anno::author("NVIDIA Corporation"),
    anno::key_words(string[]("generic", "volume")),
    anno::version(1, 0, 0, ""),
 	anno::in_group("Volumes")
]]
 = 
    let {
	float density_scale = ::math::clamp(volume_density_scale, -1e30, 1e30);
	
	color volume_scattering =  		volume_albedo;
	color volume_absorption = (1 -	volume_albedo);
	
    ::base::volume_coefficients c = 
		::base::lookup_volume_coefficients(
				volume_density_texture, 
				volume_scattering, 
				volume_absorption, 
				color(0), /* scatter_mult */
				color(0), /* absorpt_mult */ 
				float4x4(1.0f), 
				density_scale, 
				false);
				
    material_surface fake_surface(
                        ::df::specular_bsdf(color(1.f, 1.f, 1.f), ::df::scatter_transmit, ""),
                        material_emission(emission: edf(), intensity: color(0), mode: intensity_radiant_exitance));
			
    material_volume volume = 
		material_volume(
			::df::anisotropic_vdf(directional_bias, ""), 
			scattering_coefficient: c.scattering_coefficient,
			absorption_coefficient: c.absorption_coefficient);
} in material
(
	surface: fake_surface,
	ior: color(1.f),
	volume: volume
);
